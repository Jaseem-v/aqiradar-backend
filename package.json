{
  "name": "aqi-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Standalone Express + Mongoose REST API for the AQIRadar admin",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "seed": "tsx src/seed.ts",
    "care:seed": "tsx src/seedCare.ts",
    "care:reconcile": "tsx src/reconcileCare.ts",
    "care:content": "tsx src/seedCareContent.ts",
    "backfill": "tsx src/backfill.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.726.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "multer": "^2.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
