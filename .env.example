# Server
PORT=5000
# Comma-separated list of allowed origins for CORS (the admin panel URL)
CORS_ORIGINS=http://localhost:3001

# MongoDB. Uses a SEPARATE database (aqi_admin) so it never touches the
# existing Payload data in the `aqi` database on the same cluster.
MONGODB_URI=mongodb+srv://superadmin:PASSWORD@myfreelancedb.f4ai8kg.mongodb.net/aqi_admin

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Absolute base URL of this API (used to build URLs for uploaded images)
PUBLIC_URL=http://localhost:5000
MAX_UPLOAD_MB=5

# ---- Image storage ----
# STORAGE_DRIVER: "s3" or "local". If unset, defaults to "s3" when S3_BUCKET is
# set, otherwise "local". If "s3" is selected but not fully configured, the app
# automatically falls back to local disk.
STORAGE_DRIVER=local
# S3 / S3-compatible (AWS S3, Cloudflare R2, MinIO, DigitalOcean Spaces)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional: custom endpoint for non-AWS S3 (e.g. https://<acct>.r2.cloudflarestorage.com)
S3_ENDPOINT=
# Optional: public/CDN base URL in front of the bucket (else a standard S3 URL is used)
S3_PUBLIC_URL=
# Key prefix ("folder") inside the bucket
S3_PREFIX=media
# Set true for MinIO / path-style endpoints
S3_FORCE_PATH_STYLE=false

# ---- Backfill ----
# Source DB to migrate existing Payload data from. Defaults to this cluster with
# the db name swapped to "aqi".
# BACKFILL_SOURCE_URI=mongodb+srv://user:pass@host/aqi
# The Payload site's URL. Backfilled media use relative paths like
# /api/media/file/x.jpg — set this to turn them into absolute, resolvable URLs.
# FRONTEND_URL=https://your-payload-site.com

# Seed: the first admin user created by `npm run seed`
SEED_ADMIN_EMAIL=admin@aqiradar.local
SEED_ADMIN_PASSWORD=changeme123
SEED_ADMIN_NAME=Administrator
